PORT=5001
HOST=0.0.0.0
MONGO_URI=mongodb://127.0.0.1:27017/voicemind
ALLOW_START_WITHOUT_MONGO=true
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=99999999
DEVICE_OFFLINE_AFTER_SEC=60
DEVICE_CHECK_INTERVAL_SEC=10
TRANSCRIBE_API_URL=http://127.0.0.1:8001
QA_API_URL=http://127.0.0.1:8002
NODE_ENV=development
TRANSCRIBE_TIMEOUT_MS=600000
TRANSCRIBE_RETRIES=1
TRANSCRIBE_RETRY_BACKOFF_MS=1500

# ── Google Gemini (summary + analysis + QA) ─────────────────────────────────
# Get a key at https://aistudio.google.com
# Server-side only — never expose this key to the browser.
# ⚠ Do not commit a real key here. The previous example value was a real-
# looking key that was also hardcoded as a source-level fallback default —
# rotate it if it was ever in real use.
GOOGLE_API_KEY=AQ.Ab8RN6LDUM4cnAkQDJnCz2nEZsuBLIWDpRw787TVLj1ud18PyQ
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=60000
SUMMARY_MAX_INPUT_CHARS=45000
SUMMARY_MIN_CONTENT_CHARS=80
SUMMARY_MIN_CONTENT_WORDS=20

# ── QA service settings ──────────────────────────────────────────────────────
# Must comfortably exceed the Python QA service's worst-case provider time
# (Gemini timeout + Qwen/Ollama fallback timeout, sequential). 30000 was too
# short and caused long summary requests to be abandoned before the Python
# service finished generating.
QA_TIMEOUT_MS=170000
QA_CONTEXT_CHARS=32000
QA_GLOBAL_MEETING_LIMIT=8
