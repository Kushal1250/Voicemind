# =======================================================
# VoiceMind QA Service v9.0 — .env.example
# Providers: Google Gemini (primary) + Ollama Qwen2.5 (fallback)
# =======================================================
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control.

PORT=8002
DEBUG=false

# ── Provider order ──────────────────────────────────────
# Which provider tries first. The other is the automatic fallback.
# Values: "gemini" | "qwen"
QA_PRIMARY_PROVIDER=gemini

# ── Google Gemini (cloud LLM) ───────────────────────────
# Get a key at https://aistudio.google.com
# ⚠ Do not commit a real key here.
GOOGLE_API_KEY=AQ.Ab8RN6LDUM4cnAkQDJnCz2nEZsuBLIWDpRw787TVLj1ud18PyQ
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=30

# ── Qwen2.5 via Ollama (local LLM fallback) ────────────
# Install Ollama: https://ollama.com
# Pull the model:  ollama pull qwen2.5:latest
OLLAMA_BASE_URL=http://localhost:11434
QWEN_MODEL=qwen2.5:latest
OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE=0.05
OLLAMA_NUM_CTX=32000
OLLAMA_REPEAT_PENALTY=1.1

# ── Retrieval tuning ────────────────────────────────────
QA_CONTEXT_CHARS=32000
QA_TOP_K_CHUNKS=10
QA_NEIGHBOR_WINDOW=1

# ── LLM output limit ────────────────────────────────────
# This is the FLOOR for ordinary Q&A answers. Summary/meeting-notes
# questions, and any question with an explicit word-count request (e.g.
# "in 200 words"), now compute their own larger token budget at request
# time (see compute_max_tokens() in main.py) regardless of this value.
QA_MAX_LLM_TOKENS=1000

