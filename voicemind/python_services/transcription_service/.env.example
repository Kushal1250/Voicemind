# ================================================================
# VoiceMind Transcription Service — MASTER FIX CONFIG v23.0
# Fixes applied:
#   - large-v3-turbo (6x faster, same accuracy — eliminates queue buildup)
#   - LOG_PROB_THRESHOLD -1.1 → -1.5 (fewer valid Gujarati segments rejected)
#   - NO_SPEECH_THRESHOLD 0.60 → 0.65 (tolerates Indian speech pauses)
#   - COMPRESSION_RATIO_THRESHOLD 1.9 → 2.0 (Gujarati connectors: ane/che/pan)
#   - REPETITION_PENALTY=1.35 explicit (prevents decoder loops)
#   - VAD_MIN_SPEECH_RATIO 0.18 → 0.15 (keep more low-energy speech)
#   - VAD_THRESHOLD 0.52 → 0.50 (more sensitive VAD)
#   - WHISPER_NUM_WORKERS=2 (parallel decode workers)
# ================================================================

# ── Whisper Model ─────────────────────────────────────────────────────

# ── Google Gemini Transcription ────────────────────────────────────────
# Required: Google API key for Gemini transcription
GOOGLE_API_KEY=AQ.Ab8RN6LDUM4cnAkQDJnCz2nEZsuBLIWDpRw787TVLj1ud18PyQ
GEMINI_MODEL=gemini-3.5-flash

# ── Beam (greedy decode — 40-80s per 60s chunk on CPU) ────────────────
WHISPER_FAST_BEAM=1
WHISPER_FAST_BEST_OF=1
WHISPER_FAST_MAX_SEC=20.0
WHISPER_BEAM_SIZE=1
WHISPER_BEST_OF=1
WHISPER_CPU_SAFE_MODE=true
WHISPER_MEMORY_SAFE_ON_CPU=true

# ── Decoding ──────────────────────────────────────────────────────────
WHISPER_TEMPERATURES=0.0
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
WHISPER_WORD_TIMESTAMPS=false
# Repetition penalty — prevents decoder loops on Gujarati/Hindi
REPETITION_PENALTY=1.35

# ── Thresholds (tuned for Gujarati/Hindi — permissive to reduce false rejections) ──
# LOG_PROB_THRESHOLD: -1.1 was rejecting valid low-energy Gujarati speech.
#   Logs showed valid segments at no_speech=0.61-0.94 being incorrectly dropped.
#   -1.5 accepts more real speech while still rejecting true garbage.
# NO_SPEECH_THRESHOLD: 0.60 was too strict for Indian speech with natural long pauses.
#   0.65 matches actual no_speech_prob distribution seen in production logs.
# COMPRESSION_RATIO_THRESHOLD: 1.9 was flagging Gujarati connector word repetition
#   (ane, che, pan appear many times legitimately). 2.0 fixes this.
NO_SPEECH_THRESHOLD=0.65
LOG_PROB_THRESHOLD=-1.5
COMPRESSION_RATIO_THRESHOLD=2.0

# ── Initial prompt (expanded IPL 2025 cricket vocabulary) ─────────────
WHISPER_PASS_INITIAL_PROMPT=true

# ── VAD ───────────────────────────────────────────────────────────────
VAD_STANDALONE_ENABLED=true
VAD_THRESHOLD=0.50
VAD_MIN_SPEECH_RATIO=0.15
WHISPER_VAD_FILTER=false
WHISPER_VAD_RETRY_ENABLED=true
WHISPER_VAD_MIN_SILENCE_MS=500
WHISPER_VAD_SPEECH_PAD_MS=200

# ── Language ──────────────────────────────────────────────────────────
FORCE_LANGUAGE=
AUTO_LANGUAGE_CANDIDATES=gu,hi,en
WHISPER_AUTO_CANDIDATES=gu,hi,en
WHISPER_AUTO_STRATEGY=single_auto_first
WHISPER_MAX_AUTO_FALLBACK_CANDIDATES=3
WHISPER_EXPLICIT_LANG_AUTO_RETRY=true

# ── Gujarati code-switch acceptance ───────────────────────────────────
GU_ACCEPT_DEVANAGARI=true
GU_ACCEPT_HIGHCONF_ENGLISH=true

# ── IndicWhisper & MMS (disabled) ─────────────────────────────────────
ENABLE_INDIC_WHISPER=false
INDIC_WHISPER_MODEL=vasista22/whisper-gujarati-medium
INDIC_WHISPER_MODEL_HI=vasista22/whisper-hindi-medium
ENABLE_MMS_FALLBACK=false

# ── Output mode ───────────────────────────────────────────────────────
OUTPUT_SCRIPT_MODE=preserve

# ── Cross-segment repeat detection ────────────────────────────────────
CROSS_SEGMENT_REPEAT_THRESHOLD=0.70
CROSS_SEGMENT_MIN_COUNT=4

# ── Audio preprocessing ───────────────────────────────────────────────
AUDIO_PREPROCESS_MODE=enhanced
FFMPEG_BIN= ffmpeg
FFPROBE_BIN= ffprobe

# ── Chunk validation ──────────────────────────────────────────────────
MIN_CHUNK_DURATION_SEC=0.3
REJECT_BAD_CHUNKS=true

# ── Diarization (disabled) ────────────────────────────────────────────
ENABLE_SPEAKER_DIARIZATION=false
HF_TOKEN=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
ROLE_ALTERNATE_WHEN_NO_DIARIZATION=true
ROLE_ALTERNATE_MIN_SEGMENTS=2

# ── LM Studio cleanup (disabled) ──────────────────────────────────────
ENABLE_LM_STUDIO_CLEANUP=false

# ── Service ───────────────────────────────────────────────────────────
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001
PORT=8001
SERVICE_RELOAD=false

# ── Quality scoring thresholds ────────────────────────────────────────
EN_WINS_THRESHOLD=0.40
GU_HI_GIBBERISH_THRESHOLD=0.45
MIN_DICT_COVERAGE=0.15

# ── Live chunk ────────────────────────────────────────────────────────
LIVE_CHUNK_SECONDS=60
MIN_AUDIO_DURATION_SEC=0.20
ENABLE_DEMUCS_PREPROCESS=false
DEBUG=true
